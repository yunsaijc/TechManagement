# ============================================
# 数据库配置 (奖励评审 - MySQL)
# ============================================
DB_REWARD_HOST=192.168.0.xxx
DB_REWARD_PORT=3306
DB_REWARD_USER=your_user
DB_REWARD_PASSWORD=your_pwd

# ============================================
# 数据库配置 (项目评审 - SQL Server)
# ============================================
DB_PROJECT_HOST=192.168.0.xxx
DB_PROJECT_PORT=1433
DB_PROJECT_USER=your_user
DB_PROJECT_PASSWORD=your_pwd
DB_PROJECT_DATABASE=your_database

# ============================================
# LLM 配置
# ============================================
# 可选 provider: openai, anthropic, qwen, azure, minimax
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o
LLM_API_KEY=your_api_key_here
LLM_BASE_URL=

# ============================================
# 应用配置
# ============================================
APP_HOST=0.0.0.0
APP_PORT=8000
